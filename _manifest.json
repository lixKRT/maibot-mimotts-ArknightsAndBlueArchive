{
  "manifest_version": 2,
  "id": "lixKRT.maibot-mimotts-arknights-bluearchive",
  "name": "MiMo TTS Arknights And BlueArchive Voice Plugin",
  "version": "2.0.0",
  "description": "MiMo TTS Voice Clone Plugin for MaiBot - AI语音回复插件，支持自定义音色克隆、风格控制，以及蔚蓝档案和明日方舟角色语音克隆",
  "author": {
    "name": "Emilia-awa",
    "url": "https://github.com/Emilia-awa"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Emilia-awa/maibot-mimotts-voice",
    "homepage": "https://github.com/Emilia-awa/maibot-mimotts-voice"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {"type": "python_package", "name": "aiohttp", "version_spec": ">=3.8.0"},
    {"type": "python_package", "name": "selectolax", "version_spec": ">=0.3.0"},
    {"type": "python_package", "name": "pydub", "version_spec": ">=0.25.1"},
    {"type": "python_package", "name": "toml", "version_spec": ">=0.10.2"}
  ],
  "capabilities": [
    "send.text",
    "send.custom",
    "send.record",
    "message.get_by_id",
    "chat.get_all_streams"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}